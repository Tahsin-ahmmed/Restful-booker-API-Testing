            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"firstname\" : \"{{firstname}}\",\r\n    \"lastname\" : \"{{lastname}}\",\r\n    \"totalprice\" : {{totalprice}},\r\n    \"depositpaid\" : {{depositpaid}},\r\n    \"bookingdates\" : {\r\n        \"checkin\" : \"{{checkin}}\",\r\n        \"checkout\" : \"{{checkout}}\"\r\n    },\r\n    \"additionalneeds\" : \"{{additionalneeds}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/booking",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "booking"
          ]
        },
        "description": "Response Body:\n\n{  \n\"bookingid\": 1742,  \n\"booking\": {  \n\"firstname\": \"Frank\",  \n\"lastname\": \"Runolfsdottir\",  \n\"totalprice\": 511,  \n\"depositpaid\": true,  \n\"bookingdates\": {  \n\"checkin\": \"2026-05-05\",  \n\"checkout\": \"2026-05-10\"  \n},  \n\"additionalneeds\": \"Salad\"  \n}  \n}"
      },
      "response": []
    },
    {
      "name": "Get Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var responseJson = pm.response.json();\r",
              "\r",
              "if(pm.response.code == 200){\r",
              "    pm.test(\"First Name Validation\", function () {\r",
              "    pm.expect(pm.environment.get(\"firstname\")).to.eql(responseJson.firstname);\r",
              "    });\r",
              "    pm.test(\"Last Name Validation\", function () {\r",
              "        pm.expect(pm.environment.get(\"lastname\")).to.eql(responseJson.lastname);\r",
              "    });\r",
              "    pm.test(\"Total Price Validation\", function () {\r",
              "        let expectedPrice = parseInt(pm.environment.get(\"totalprice\"));\r",
              "        pm.expect(expectedPrice).to.eql(responseJson.totalprice);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Deposit Paid Validation\", function () {\r",
              "        pm.expect(pm.environment.get(\"depositpaid\")).to.eql(responseJson.depositpaid.toString());\r",
              "    });\r",
              "\r",
              "    pm.test(\"Check-in Date Validation\", function () {\r",
              "        pm.expect(pm.environment.get(\"checkin\")).to.eql(responseJson.bookingdates.checkin);\r",
              "    });\r",
              "    pm.test(\"Check-out Date Validation\", function () {\r",
              "        pm.expect(pm.environment.get(\"checkout\")).to.eql(responseJson.bookingdates.checkout);\r",
              "    });\r",
              "} else if (pm.response.code == 404){\r",
              "    pm.test(\"Booking Not Found\")\r",
              "} else {\r",
              "    pm.test(\"Unexpected Response Code\")\r",
              "}\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
